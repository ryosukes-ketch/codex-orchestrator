# API provider keys (optional; adapters run in mock fallback by default)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROK_API_KEY=your_grok_api_key_here

# State backend
# memory | postgres
STATE_BACKEND=memory

# Used when STATE_BACKEND=postgres
DATABASE_URL=

# true: fail startup if postgres config/connect fails
# false: fallback to in-memory repository
STATE_BACKEND_STRICT=false

# true: unsupported trend provider names fail with conflict
# false: unsupported names fall back to mock provider
TREND_PROVIDER_STRICT=false

# Dev authentication
# true: require bearer token for approval/reject/revision/replanning APIs
DEV_AUTH_ENABLED=true

# Optional override for dev token seed.
# Format:
# token:actor_id:actor_role:actor_type,token2:actor_id2:actor_role2:actor_type2
# Example:
# DEV_AUTH_TOKEN_SEED=dev-admin-token:admin-1:admin:human,dev-approver-token:approver-1:approver:human
DEV_AUTH_TOKEN_SEED=

# Test-only database URL for PostgreSQL integration tests
TEST_DATABASE_URL=
